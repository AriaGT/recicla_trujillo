<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="app.RewardsPage"
             Title="Rewards">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="↻" Order="Secondary" Priority="0" Clicked="OnRefreshClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Label Text="Tienda de Rewards"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label x:Name="StatusLabel"
                   TextColor="Gray"
                   LineBreakMode="WordWrap" />

            <CollectionView x:Name="RewardsCollectionView" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="12" Margin="0,4" BorderColor="LightGray">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding PriceText}" />
                                <Label Text="{Binding StockText}" />
                                <Button Text="Agregar al carrito"
                                        CommandParameter="{Binding Id}"
                                        Clicked="OnAddToCartClicked" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Carrito local"
                   FontSize="20"
                   FontAttributes="Bold" />

            <CollectionView x:Name="CartCollectionView" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="12" Margin="0,4" BorderColor="LightGray">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding QuantityText}" />
                                <Label Text="{Binding SubtotalText}" />
                                <Button Text="Quitar uno"
                                        CommandParameter="{Binding RewardId}"
                                        Clicked="OnRemoveFromCartClicked" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label x:Name="CartTotalLabel"
                   FontSize="16"
                   FontAttributes="Bold" />

            <Button Text="Limpiar carrito" Clicked="OnClearCartClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
