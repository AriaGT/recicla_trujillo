<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="app.Components.InfoRowView">
    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="0,4">
        <Label Grid.Column="0"
               Text="{Binding Title, Source={RelativeSource AncestorType={x:Type ContentView}}}"
               FontAttributes="Bold"
               TextColor="#2F4F4F" />
        <Label Grid.Column="1"
               Text="{Binding Value, Source={RelativeSource AncestorType={x:Type ContentView}}}"
               TextColor="#2F4F4F" />
    </Grid>
</ContentView>
