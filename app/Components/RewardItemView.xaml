<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="app.Components.RewardItemView">
    <Border Stroke="#DADADA" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="12" Margin="0,0,0,10">
        <VerticalStackLayout Spacing="8">
            <Label Text="{Binding RewardName, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="#2F4F4F" />
            <Label Text="{Binding RequiredPointsText, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                   TextColor="#2F4F4F" />
            <Label Text="{Binding StockText, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                   TextColor="#2F4F4F" />
            <Button Text="Canjear"
                    BackgroundColor="#2F4F4F"
                    TextColor="White"
                    Clicked="OnRedeemClicked" />
        </VerticalStackLayout>
    </Border>
</ContentView>
