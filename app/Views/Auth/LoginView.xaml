<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="app.Views.Auth.LoginView"
             Title="Iniciar sesión">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Label Text="Recicla Trujillo"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#2F4F4F" />

            <Label Text="Ingresa tu DNI"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#2F4F4F" />

            <Border Stroke="#2F4F4F" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,6">
                <Entry x:Name="DniEntry"
                       Placeholder="DNI"
                       Keyboard="Numeric"
                       MaxLength="8" />
            </Border>

            <Button x:Name="LoginButton"
                    Text="Iniciar sesión"
                    BackgroundColor="#2F4F4F"
                    TextColor="White"
                    Clicked="OnLoginClicked" />

            <Button Text="Crear cuenta"
                    BackgroundColor="#6B8E8E"
                    TextColor="White"
                    Clicked="OnGoToRegisterClicked" />

            <Label x:Name="StatusLabel"
                   TextColor="Red"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
