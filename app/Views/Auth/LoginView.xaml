<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="app.Views.Auth.LoginView"
    NavigationPage.HasNavigationBar="False"
    Title="Iniciar sesión"
>
    <ScrollView>
        <VerticalStackLayout
            Padding="24"
            Spacing="14"
            BackgroundColor="{DynamicResource ViewBackground}"
        >
            <Label
                Text="Recicla Trujillo"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="{DynamicResource Primary}"
            />

            <Label
                Text="Ingresa tu DNI"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="{DynamicResource PrimaryDarkText}"
            />

            <Entry
                x:Name="DniEntry"
                Placeholder="DNI"
                Keyboard="Numeric"
                MaxLength="8"
            />

            <Button
                x:Name="LoginButton"
                Text="Iniciar sesión"
                BackgroundColor="{DynamicResource Primary}"
                TextColor="{DynamicResource White}"
                Clicked="OnLoginClicked"
            />

            <Button
                Text="Crear cuenta"
                BackgroundColor="{DynamicResource Secondary}"
                TextColor="{DynamicResource Primary}"
                Clicked="OnGoToRegisterClicked"
            />

            <Label
                x:Name="StatusLabel"
                TextColor="{DynamicResource Gray500}"
                LineBreakMode="WordWrap"
            />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
